# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://your-app.vercel.app"

# Encryption (AES-256-GCM key, 64-char hex)
ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# Cron job authentication
CRON_SECRET="your-cron-secret"

# Optional: Korea Exim Bank API for live exchange rates (fallback: 1450 KRW/USD)
# KOREAEXIM_API_KEY="your-api-key"

# Optional: Shopify Client Credentials (only if using Shopify direct auth)
# SHOPIFY_CLIENT_ID="your-client-id"
# SHOPIFY_CLIENT_SECRET="your-client-secret"
